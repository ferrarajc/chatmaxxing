VITE_AWS_REGION=us-east-1
VITE_CCP_URL=https://bobs-mutual-funds.my.connect.aws/ccp-v2/
VITE_CONNECT_INSTANCE_URL=https://467c849e-e16e-404a-b9f8-ebb623f84c8b.my.connect.aws
