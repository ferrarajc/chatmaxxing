# Normal development needs NO setup: `npm run dev` already targets the DEV backend via the
# committed .env.development (see docs/PROCESS.md). Create .env.local (gitignored) ONLY to
# override — e.g. to point local dev at PROD data, set VITE_API_URL to the prod API Gateway URL.
VITE_API_URL=https://REPLACE_WITH_API_GATEWAY_URL
VITE_AWS_REGION=us-east-1
VITE_CCP_URL=https://REPLACE_WITH_INSTANCE_ID.my.connect.aws/ccp-v2
